<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="demo_partner_globex" model="res.partner">
            <field name="name">Globex Corporation</field>
            <field name="is_company" eval="True"/>
            <field name="email">contact@globex.example.com</field>
        </record>

        <record id="demo_lead_globex" model="crm.lead">
            <field name="name">Globex - ERP rollout</field>
            <field name="type">opportunity</field>
            <field name="partner_id" ref="demo_partner_globex"/>
            <field name="expected_revenue">45000</field>
            <field name="probability">60</field>
        </record>

        <record id="demo_interaction_discovery" model="sales.crm.interaction">
            <field name="name">Discovery call</field>
            <field name="interaction_type">call</field>
            <field name="direction">outbound</field>
            <field name="lead_id" ref="demo_lead_globex"/>
            <field name="partner_id" ref="demo_partner_globex"/>
            <field name="summary">Walked through current pain points and rollout timeline.</field>
        </record>

        <record id="demo_followup_proposal" model="sales.crm.followup">
            <field name="name">Send tailored proposal</field>
            <field name="lead_id" ref="demo_lead_globex"/>
            <field name="priority">2</field>
            <field name="due_date"
                   eval="(datetime.now() + timedelta(days=3)).strftime('%Y-%m-%d')"/>
        </record>

    </data>
</odoo>
