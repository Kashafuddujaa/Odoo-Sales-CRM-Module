<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sales_crm_followup_tree" model="ir.ui.view">
        <field name="name">sales.crm.followup.tree</field>
        <field name="model">sales.crm.followup</field>
        <field name="arch" type="xml">
            <tree string="Follow-ups" decoration-danger="is_overdue" decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'">
                <field name="due_date"/>
                <field name="name"/>
                <field name="lead_id"/>
                <field name="partner_id" optional="show"/>
                <field name="user_id"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'planned'"/>
                <field name="is_overdue" invisible="1"/>
                <button name="action_mark_done" type="object" string="Done"
                        icon="fa-check" invisible="state != 'planned'"/>
            </tree>
        </field>
    </record>

    <record id="view_sales_crm_followup_form" model="ir.ui.view">
        <field name="name">sales.crm.followup.form</field>
        <field name="model">sales.crm.followup</field>
        <field name="arch" type="xml">
            <form string="Follow-up">
                <header>
                    <button name="action_mark_done" type="object" string="Mark Done"
                            class="oe_highlight" invisible="state != 'planned'"/>
                    <button name="action_mark_cancelled" type="object" string="Cancel"
                            invisible="state != 'planned'"/>
                    <button name="action_reset_planned" type="object" string="Reset to Planned"
                            invisible="state == 'planned'"/>
                    <field name="state" widget="statusbar" statusbar_visible="planned,done"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Overdue" bg_color="text-bg-danger"
                            invisible="not is_overdue"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Send revised quote"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="lead_id"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="due_date"/>
                            <field name="priority" widget="priority"/>
                            <field name="done_date" invisible="state != 'done'"/>
                            <field name="is_overdue" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Details for this follow-up..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_sales_crm_followup_calendar" model="ir.ui.view">
        <field name="name">sales.crm.followup.calendar</field>
        <field name="model">sales.crm.followup</field>
        <field name="arch" type="xml">
            <calendar string="Follow-ups" date_start="due_date" color="user_id" mode="month">
                <field name="name"/>
                <field name="lead_id"/>
                <field name="user_id" filters="1"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_sales_crm_followup_search" model="ir.ui.view">
        <field name="name">sales.crm.followup.search</field>
        <field name="model">sales.crm.followup</field>
        <field name="arch" type="xml">
            <search string="Follow-ups">
                <field name="name"/>
                <field name="lead_id"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <filter name="my_followups" string="My Follow-ups" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="planned" string="Planned" domain="[('state', '=', 'planned')]"/>
                <filter name="overdue" string="Overdue" domain="[('is_overdue', '=', True)]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="due_today" string="Due Today"
                        domain="[('due_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_user" string="Assigned To" context="{'group_by': 'user_id'}"/>
                    <filter name="group_due" string="Due Date" context="{'group_by': 'due_date:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sales_crm_followup" model="ir.actions.act_window">
        <field name="name">Follow-ups</field>
        <field name="res_model">sales.crm.followup</field>
        <field name="view_mode">tree,calendar,form</field>
        <field name="search_view_id" ref="view_sales_crm_followup_search"/>
        <field name="context">{'search_default_my_followups': 1, 'search_default_planned': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Schedule your first follow-up</p>
            <p>Never lose a deal to silence. Plan follow-ups and get reminded when they fall overdue.</p>
        </field>
    </record>

</odoo>
