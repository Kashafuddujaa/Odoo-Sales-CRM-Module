<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Application security category shown under Settings > Users -->
        <record id="module_category_sales_crm" model="ir.module.category">
            <field name="name">Sales CRM</field>
            <field name="description">Access rights for the Sales CRM application.</field>
            <field name="sequence">15</field>
        </record>

        <!-- Tier 1: Salesperson - sees and manages their own records -->
        <record id="group_sales_crm_user" model="res.groups">
            <field name="name">Salesperson</field>
            <field name="category_id" ref="module_category_sales_crm"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Tier 2: Manager - sees and manages all records -->
        <record id="group_sales_crm_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_sales_crm"/>
            <field name="implied_ids" eval="[(4, ref('group_sales_crm_user'))]"/>
        </record>

        <!-- Tier 3: Administrator - manager rights plus configuration access -->
        <record id="group_sales_crm_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_sales_crm"/>
            <field name="implied_ids" eval="[(4, ref('group_sales_crm_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record rules: Interactions -->
        <record id="rule_interaction_own" model="ir.rule">
            <field name="name">Interaction: own records</field>
            <field name="model_id" ref="model_sales_crm_interaction"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_crm_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_interaction_all" model="ir.rule">
            <field name="name">Interaction: all records (manager)</field>
            <field name="model_id" ref="model_sales_crm_interaction"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_crm_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record rules: Follow-ups -->
        <record id="rule_followup_own" model="ir.rule">
            <field name="name">Follow-up: own records</field>
            <field name="model_id" ref="model_sales_crm_followup"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_sales_crm_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_followup_all" model="ir.rule">
            <field name="name">Follow-up: all records (manager)</field>
            <field name="model_id" ref="model_sales_crm_followup"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_sales_crm_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
